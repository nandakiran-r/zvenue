# ═══════════════════════════════════════════════════════════════════════════════
# ZVenue Backend — Production Environment Variables
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your production values
# NEVER commit the actual .env file to version control
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Server ─────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ─── Database (Neon PostgreSQL) ─────────────────────────────────────────────
# Get from: https://console.neon.tech → Project → Connection Details
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# ─── CORS Origins ──────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://your-admin-domain.com

# ─── Authentication ────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=your_random_64_char_hex_secret_here
JWT_SECRET=your_random_jwt_secret_here
# Public URL of this backend (used for receipt URLs sent via WhatsApp)
BETTER_AUTH_URL=https://your-backend-domain.com

# ─── Razorpay (Payment Gateway) ────────────────────────────────────────────
# Get from: https://dashboard.razorpay.com → Settings → API Keys
# IMPORTANT: Use LIVE keys for production (rzp_live_xxx), NOT test keys (rzp_test_xxx)
RAZORPAY_KEY_ID=rzp_live_YOUR_LIVE_KEY_ID
RAZORPAY_KEY_SECRET=YOUR_LIVE_KEY_SECRET
# Webhook secret: Dashboard → Webhooks → Create → Copy secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# ─── AOC WhatsApp API ──────────────────────────────────────────────────────
# Get from: https://aoc-portal.com → API Settings
AOC_API_KEY=your_aoc_api_key
AOC_WHATSAPP_NUMBER=+917249111100

# Template names (must match templates created in AOC portal)
AOC_TEMPLATE_NAME=otp
AOC_PREBOOKING_TEMPLATE_NAME=booking_notification
AOC_SERVICE_BOOKING_TEMPLATE_NAME=notification
AOC_OWNER_PREBOOKING_TEMPLATE_NAME=pre_booking_owner_notification
AOC_INVOICE_TEMPLATE_NAME=booking_confirmation_invoice

# ─── MSG2Z SMS (OTP Fallback) ──────────────────────────────────────────────
MSG2Z_USER_ID=zvenue
MSG2Z_PASSWORD=your_msg2z_password
MSG2Z_SENDER_ID=ZVENUE
MSG2Z_ENTITY_ID=1701177875328026717
MSG2Z_TEMPLATE_ID=1707177882344538316

# ─── Cloudinary (File Storage) ─────────────────────────────────────────────
# Used for receipt PDF storage (backup)
# Cloud name and preset are also used by admin panel for image uploads
# Preset must be: Unsigned mode, Auto resource type
CLOUDINARY_CLOUD_NAME=dxprjeaun
CLOUDINARY_UPLOAD_PRESET=zvenue_unsigned
