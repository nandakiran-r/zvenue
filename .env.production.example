# ═══════════════════════════════════════════════════════════════════════════════
# ZVenue Mobile App — Production Environment Variables
# ═══════════════════════════════════════════════════════════════════════════════
# These are build-time variables (prefixed with EXPO_PUBLIC_) embedded into the app
# Set these in eas.json under build.production.env OR in EAS Secrets
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Backend API URL ───────────────────────────────────────────────────────
# The public URL of your backend server
EXPO_PUBLIC_API_URL=https://your-backend-domain.com

# ─── Razorpay (Payment Gateway) ───────────────────────────────────────────
# IMPORTANT: Use LIVE key for production (rzp_live_xxx)
EXPO_PUBLIC_RAZORPAY_KEY=rzp_live_YOUR_LIVE_KEY_ID

# ─── Cloudinary (Image Uploads) ───────────────────────────────────────────
# Used for profile avatar uploads from mobile app
EXPO_PUBLIC_CLOUDINARY_CLOUD=dxprjeaun
EXPO_PUBLIC_CLOUDINARY_PRESET=zvenue_unsigned
