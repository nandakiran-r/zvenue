# ═══════════════════════════════════════════════════════════════════════════════
# ZVenue Admin Panel — Production Environment Variables
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your production values
# These are build-time variables (prefixed with VITE_) embedded into the bundle
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Backend API URL ───────────────────────────────────────────────────────
# The public URL of your backend server
VITE_API_URL=https://your-backend-domain.com

# ─── Cloudinary (Image Uploads) ───────────────────────────────────────────
# Used for venue/service image uploads from admin panel
VITE_CLOUDINARY_CLOUD=dxprjeaun
VITE_CLOUDINARY_PRESET=zvenue_unsigned
